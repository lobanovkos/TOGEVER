# ============================================================
# TOGEVER Environment Variables
# ============================================================
# Copy this file to .env (locally) or set these in Railway dashboard
# DO NOT commit .env to git!

# ── TURN Server Credentials (Metered.ca) ──────────────────
# Get these free at: https://dashboard.metered.ca/signup
# After signup → TURN Credentials → Create Application
VITE_TURN_USERNAME=your_username_here
VITE_TURN_CREDENTIAL=your_credential_here
